<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's V8 + sandboxed renderers under hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- node-pty spawns child processes (the user's shell, claude, gh). -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Klaussy makes outbound network calls (gh, GitHub API, npm registry on auto-clone). -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- NOTE: com.apple.security.files.user-selected.read-write was removed.
       It is a sandbox-only entitlement that activates PowerBox + scoped
       bookmark serialization for NSOpenPanel selections. Klaussy is
       hardened-runtime but NOT sandboxed, so it already has POSIX
       filesystem access and doesn't need PowerBox. Leaving it on caused a
       hang on some machines where com.apple.ScopedBookmarkAgent was
       unresponsive — NSOpenPanel's dismiss handler blocks in a sync XPC
       call to that daemon (see sample: syncMessageToScopedBookmarksAgent
       → mach_msg2_trap). Force-quit was the only recovery. -->
</dict>
</plist>

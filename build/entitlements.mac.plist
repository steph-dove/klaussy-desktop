<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's V8 + sandboxed renderers under hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- node-pty spawns child processes (the user's shell, claude, gh). -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Klaussy makes outbound network calls (gh, GitHub API, npm registry on auto-clone). -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Read user-selected files / dirs (project picker, basepath browse). -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>

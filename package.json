{
  "name": "klaus-desktop",
  "productName": "Klaussy",
  "version": "0.1.8",
  "description": "Multi-terminal Claude Code worktree manager + GitHub PR reviewer for macOS and Windows",
  "main": "main.js",
  "author": "steph-dove",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/steph-dove/klausify-desktop.git"
  },
  "scripts": {
    "start": "electron .",
    "test": "node --test test/util/*.test.js",
    "rebuild": "electron-rebuild",
    "dist": "electron-builder --mac --arm64 --x64 && npm run rebuild",
    "dist:arm64": "electron-builder --mac --arm64 && npm run rebuild",
    "dist:intel": "electron-builder --mac --x64 && npm run rebuild",
    "dist:win": "electron-builder --win --x64 && npm run rebuild",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "highlight.js": "^11.11.1",
    "monaco-editor": "^0.45.0",
    "node-pty": "^1.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^4.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.steph-dove.klaussy",
    "productName": "Klaussy",
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "main.js",
      "main/**/*",
      "lsp-manager.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "icon.icns",
      "icon.ico",
      "icon.png",
      "!**/.DS_Store",
      "!**/test/**",
      "!**/tests/**",
      "!**/*.md"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "afterSign": "build/notarize.js",
    "dmg": {
      "title": "Klaussy ${version} ${arch}",
      "icon": "icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icon.ico",
      "artifactName": "${productName}-${version}-${arch}-${ext}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Klaussy",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "steph-dove",
      "repo": "klausify-desktop-feedback",
      "releaseType": "release"
    }
  }
}

node_modules/
dist/
out/
# build/ is electron-builder's output dir — ignore everything *inside* it
# but allow the source files we ship (entitlements + notarize hook). Using
# `build/*` instead of `build/` so git walks the dir and the re-includes
# below take effect.
build/*
!build/entitlements.mac.plist
!build/notarize.js
!build/win-sign.js
icon.iconset/
*.log
npm-debug.log*
.DS_Store
.env
.env.*
# Unrelated Swift/Xcode project co-located in this repo; has its own .git.
Klaussy/
# Claude Code local settings are per-user and must not be committed.
.claude/settings.local.json
# Editor scratch
.vscode/
.idea/
*.swp
*.swo
.claude/
# Playwright e2e artifacts
playwright-report/
test-results/
.playwright/

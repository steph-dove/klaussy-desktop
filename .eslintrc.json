{
  "root": true,
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "out/",
    "release/",
    "renderer/styles/",
    "renderer/hljs-bundle.js",
    "renderer/monaco-init.js",
    "renderer/monaco-typescript.js",
    "**/*.min.js"
  ],
  "overrides": [
    {
      "files": ["main/**/*.js", "main.js", "preload.js"],
      "parserOptions": { "ecmaVersion": 2022, "sourceType": "script" },
      "env": { "node": true, "es2022": true },
      "rules": { "no-undef": "error" }
    },
    {
      "files": ["renderer/**/*.js"],
      "parserOptions": { "ecmaVersion": 2022, "sourceType": "script" },
      "env": { "browser": true, "es2022": true },
      "globals": {
        "require": "readonly",
        "define": "readonly",
        "module": "writable",
        "process": "readonly",
        "Terminal": "readonly",
        "FitAddon": "readonly",
        "SearchAddon": "readonly",
        "WebLinksAddon": "readonly",
        "markdownit": "readonly",
        "DOMPurify": "readonly",
        "monaco": "readonly",
        "hljs": "readonly",
        "_addWorktreeToSidebar": "writable",
        "_pendingAgentNav": "writable",
        "_reloadDiffTab": "writable",
        "_showContextMenu": "writable",
        "ActionModal": "writable",
        "AgentRouter": "writable",
        "AgentsPanel": "writable",
        "AgentSplit": "writable",
        "AppState": "writable",
        "AppUtils": "writable",
        "BranchlessUI": "writable",
        "closeFileViewerOnTaskSwitch": "writable",
        "CommandPalette": "writable",
        "ConflictPanel": "writable",
        "ContextMenu": "writable",
        "Dialogs": "writable",
        "DiffPanel": "writable",
        "enterPrReviewMode": "writable",
        "EnvPanel": "writable",
        "Events": "writable",
        "exitPrReviewMode": "writable",
        "FileBrowser": "writable",
        "FindingParser": "writable",
        "getMonaco": "writable",
        "HistoryPanel": "writable",
        "InlineComplete": "writable",
        "InlineEdit": "writable",
        "LicenseActivation": "writable",
        "LspClient": "writable",
        "MarkdownPreview": "writable",
        "MonacoProject": "writable",
        "OllamaConsent": "writable",
        "openFileViewer": "writable",
        "pickDirectoryPopup": "writable",
        "ProjectSwitcher": "writable",
        "PRPanel": "writable",
        "PrReview": "writable",
        "PrReviewFindings": "writable",
        "PrReviewTerminal": "writable",
        "PrReviewComments": "writable",
        "PrReviewCore": "writable",
        "QuickOpen": "writable",
        "runApp": "writable",
        "SearchBar": "writable",
        "Sidebar": "writable",
        "StashPanel": "writable",
        "TerminalManager": "writable",
        "ThemeManager": "writable",
        "toast": "writable",
        "toggleBlame": "writable",
        "WordComplete": "writable"
      },
      "rules": { "no-undef": "error" }
    }
  ]
}
